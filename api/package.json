{
  "name": "vet-api",
  "version": "1.0.0",
  "description": "REST API for Vet App - Headless veterinary practice management",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:generate": "bun run src/db/generate.ts",
    "openapi:generate": "bun run src/scripts/generate-openapi.ts"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.23.0",
    "@hono/zod-validator": "^0.4.0",
    "postgres": "^3.4.0",
    "drizzle-orm": "^0.33.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.6.0"
  }
}