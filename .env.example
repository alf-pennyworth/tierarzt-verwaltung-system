# Vet App Environment Variables
# Copy this file to .env and fill in your values

# ========================================
# Supabase (Required)
# ========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================================
# AI APIs (Required for AI endpoints)
# ========================================

# AssemblyAI - Audio transcription
# Get key at: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your-assemblyai-key

# Gemini - Medical extraction and SOAP notes
# Get key at: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-key

# ========================================
# API Server
# ========================================
PORT=3001

# CORS - Allowed origins for production (comma-separated)
# Example: CORS_ORIGIN=https://vet-app.de,https://app.vet-app.de
# Development localhost origins are always allowed
CORS_ORIGIN=

# ========================================
# Optional: UPD Drug Database Integration
# ========================================
# Register at: https://accounts.ema.europa.eu/
UPD_CLIENT_ID=
UPD_CLIENT_SECRET=

# ========================================
# Demo Credentials (for testing)
# ========================================
# Email: demo@tierarzt-app.de
# Password: demo123456