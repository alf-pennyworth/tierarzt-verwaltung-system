# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Supabase - Safe to expose in frontend
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================================
# IMPORTANT: Backend secrets should NOT be in this file!
# ============================================================
# For Edge Functions, set secrets in Supabase Dashboard:
# Project Settings > Edge Functions > Secrets
#
# Required secrets for Edge Functions:
# - ASSEMBLY_AI_API_KEY
# - GEMINI_API_KEY
# - SUPABASE_SERVICE_ROLE_KEY (if needed)
#
# DO NOT prefix backend secrets with VITE_ - they will be
# exposed in the frontend bundle!